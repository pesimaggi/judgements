{
  "name": "logbrunnur",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial legal research search across Icelandic, EEA and EU sources",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:setup-search": "tsx prisma/setup-search.ts",
    "db:deploy": "prisma db push --accept-data-loss && tsx prisma/setup-search.ts",
    "db:seed": "tsx prisma/seed.ts",
    "ingest": "tsx src/ingestion/run.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "cheerio": "^1.0.0",
    "meilisearch": "^0.41.0",
    "next": "^14.2.5",
    "pdf-parse": "^1.1.1",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
